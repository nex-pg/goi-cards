# 環境変数のサンプル。コピーして .env を作成し値を入れる（.env は git 管理外）。
# Expo は EXPO_PUBLIC_ 接頭辞の変数だけをアプリ(JS)に埋め込む。
# 値が無い場合: PostHog/RevenueCat は自動的に無効(no-op)になり、アプリは通常どおり動く。

# --- PostHog（分析・任意） ---
# 未設定なら一切送信しない。設定すると計測が有効化される。
EXPO_PUBLIC_POSTHOG_KEY=
# 取得先リージョンに合わせて（米国: https://us.i.posthog.com / EU: https://eu.i.posthog.com）
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- RevenueCat（課金） ---
# RevenueCat の「APIキー」→ Apple App Store 用の public SDK key（appl_ から始まる）
EXPO_PUBLIC_RC_IOS_KEY=
# Android を出すとき（goog_ から始まる）。iOS先行なら空でよい。
EXPO_PUBLIC_RC_ANDROID_KEY=
